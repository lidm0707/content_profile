# ============================================
# Supabase Configuration
# ============================================
# Copy this file to .env and add your actual Supabase credentials
# Do NOT commit .env to version control!
APP_MODE=supabase

# Your Supabase project URL
# Get this from: https://supabase.com/dashboard/project/_/settings/api
# Look for "Project URL"
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key
# Get this from: https://supabase.com/dashboard/project/_/settings/api
# Look for "anon" or "public" key under "Project API keys"
# This key allows public access to your database (with RLS policies)
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Optional Configuration
# ============================================

# Service role key (for admin operations - use with caution!)
# Get this from: https://supabase.com/dashboard/project/_/settings/api
# Look for "service_role" key under "Project API keys"
# WARNING: Never use this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database connection string (for direct database access)
# Format: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Get this from: https://supabase.com/dashboard/project/_/settings/database
# Look for "Connection string" and select "URI"
# DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Application environment
# Options: development, staging, production
APP_ENV=development

# Enable debug logging
# Options: true, false
DEBUG=false

# ============================================
# Getting Your Supabase Credentials
# ============================================
#
# 1. Go to https://supabase.com
# 2. Sign up or log in
# 3. Create a new project (or select existing)
# 4. Wait for the project to be ready (~2 minutes)
# 5. Navigate to: Settings → API
# 6. Copy the values from there to this file
#
# ============================================
# Security Notes
# ============================================
#
# - Never commit .env to version control (it's in .gitignore)
# - Never share your service_role key publicly
# - The anon key is safe for client-side use when RLS is enabled
# - Rotate your keys regularly for security
# - Use different keys for different environments
#
# ============================================
